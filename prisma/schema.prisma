generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String  @id @default(uuid())
  username      String  @unique
  codePin       String  // stores the 4-digit code
  isAdmin       Boolean @default(false)
  partnerId     String?
  favoriteColor String @default("#ffffff")
  coupleName    String?
  scores        Score[]
}

model Score {
  id      String   @id @default(uuid())
  score   Int
  date    String   // stores string 'YYYY-MM-DD'
  
  userId  String
  user    User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
